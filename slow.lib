library(slow) {
  delay_model : table_lookup;
  time_unit : "1ns";
  voltage_unit : "1V";
  current_unit : "1mA";
  leakage_power_unit : "1nW";
  capacitive_load_unit (1,pf);
  nom_process : 1;
  nom_voltage : 0.95;
  nom_temperature : 125.0;
  operating_conditions(slow) {
    process : 1;
    voltage : 0.95;
    temperature : 125.0;
    tree_type : balanced_tree;
  }
  default_operating_conditions : slow;

cell (INVX1) {
  area : 1.064;
  cell_leakage_power : 1.0;
  cell_footprint : inv;
  pin (A) {
    direction : input;
    capacitance : 0.0021;
  }
  pin (Y) {
    direction : output;
    function : "!A";
    max_capacitance : 0.4;
    timing () {
      related_pin : "A";
      timing_sense : negative_unate;
      cell_rise (scalar) { values("0.0386"); }
      cell_fall (scalar) { values("0.0367"); }
    }
    internal_power () {
      related_pin : "A";
      rise_power (scalar) { values("0.45"); }
      fall_power (scalar) { values("0.405"); }
    }
  }
}

